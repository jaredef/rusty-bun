{
  "name": "dotenv",
  "version": "16.4.0",
  "description": "Loads environment variables from .env files (dotenv-shape, vendored equivalent).",
  "license": "BSD-2-Clause",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.mjs",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "default": "./lib/index.mjs"
    },
    "./parse": {
      "import": "./lib/parse.mjs",
      "default": "./lib/parse.mjs"
    }
  }
}
